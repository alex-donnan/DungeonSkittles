function Statistics() constructor {
    inventory = new Inventory();
    
    // Upgrades
    start_rpm = 400;
    
    // Random stats
    play_time = 0;
    run_count = 0;
    
    damage_done = 0;
    gems_collected = 0;
    items_collected = 0;
    
    distance_travelled = 0;
    bounces = 0;
}